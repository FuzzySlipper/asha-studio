{
  "schemaVersion": 1,
  "summary": "ASHA Studio may consume approved public ASHA package roots only. Request new public ASHA surfaces in ASHA instead of importing internals or raw transports.",
  "consumerRole": "asha-studio",
  "publicSurfaceManifest": "../asha/harness/public-surface/ts-packages.json",
  "allowedLocalPackageLinks": {
    "@asha/command-registry": "link:../asha/ts/packages/command-registry",
    "@asha/catalog-core": "link:../asha/ts/packages/catalog-core",
    "@asha/contracts": "link:../asha/ts/packages/contracts",
    "@asha/devtools": "link:../asha/ts/packages/devtools",
    "@asha/editor-tools": "link:../asha/ts/packages/editor-tools",
    "@asha/game-workspace": "link:../asha/ts/packages/game-workspace",
    "@asha/render-projection": "link:../asha/ts/packages/render-projection",
    "@asha/runtime-bridge": "link:../asha/ts/packages/runtime-bridge"
  },
  "requiredLocalPackageLinks": {
    "@asha/command-registry": "link:../asha/ts/packages/command-registry",
    "@asha/catalog-core": "link:../asha/ts/packages/catalog-core",
    "@asha/contracts": "link:../asha/ts/packages/contracts",
    "@asha/devtools": "link:../asha/ts/packages/devtools",
    "@asha/editor-tools": "link:../asha/ts/packages/editor-tools",
    "@asha/game-workspace": "link:../asha/ts/packages/game-workspace",
    "@asha/render-projection": "link:../asha/ts/packages/render-projection",
    "@asha/runtime-bridge": "link:../asha/ts/packages/runtime-bridge"
  },
  "forbiddenPackages": [
    "@asha/native-bridge",
    "@asha/wasm-replay-bridge"
  ],
  "forbiddenImportSpecifiers": [
    "@asha/native-bridge",
    "@asha/wasm-replay-bridge",
    "voxelforge"
  ],
  "forbiddenImportPatterns": [
    "@asha/*/src/*",
    "@asha/*/dist/generated/*",
    "../asha/engine-rs/*",
    "/home/dev/asha/engine-rs/*",
    "../voxelforge/*",
    "/home/dev/voxelforge/*",
    "voxelforge/*",
    "@voxelforge/*"
  ],
  "dependencySections": [
    "dependencies",
    "devDependencies",
    "peerDependencies",
    "optionalDependencies",
    "pnpm.overrides",
    "overrides",
    "resolutions"
  ],
  "forbiddenText": [
    "/home/dev/asha/engine-rs",
    "engine-rs/crates",
    "src/generated",
    "call(methodName, json)",
    "postMessage({type, payload:any})",
    "payload: any",
    "payload:any",
    "Record<string, unknown> command"
  ],
  "forbiddenConfigPathFragments": [
    "../asha/ts/packages",
    "..\\asha\\ts\\packages",
    "/home/dev/asha/ts/packages",
    "../asha/engine-rs",
    "/home/dev/asha/engine-rs"
  ],
  "allowedConfigPathFiles": [
    "package.json",
    "pnpm-lock.yaml",
    "boundary-policy.json"
  ],
  "docsOnlyFiles": [
    "README.md",
    "AGENTS.md",
    "test/boundary-check.test.ts"
  ]
}
