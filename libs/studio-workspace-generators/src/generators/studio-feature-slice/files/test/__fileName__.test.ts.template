import assert from 'node:assert/strict';
import { test } from 'node:test';
import {
  buildInitialWorkspaceReadModel,
  build<%= className %>ReadModel,
} from '@asha-studio/domain';

test('<%= fileName %> read model exposes visible workspace content', () => {
  const workspace = buildInitialWorkspaceReadModel();
  const readModel = build<%= className %>ReadModel(workspace);

  assert.equal(readModel.readModelVersion, '<%= fileName %>.read-model.v0');
  assert.equal(readModel.entityCount, workspace.entities.length);
  assert.equal(readModel.selectedEntityId, workspace.selectedEntityId);
});
